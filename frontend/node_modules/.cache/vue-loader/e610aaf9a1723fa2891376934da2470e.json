{"remainingRequest":"/mnt/mural/club/club_management-main/club_management-main/frontend/node_modules/vue-loader/lib/index.js??vue-loader-options!/mnt/mural/club/club_management-main/club_management-main/frontend/src/views/club-select/index.vue?vue&type=script&lang=js","dependencies":[{"path":"/mnt/mural/club/club_management-main/club_management-main/frontend/src/views/club-select/index.vue","mtime":1763210516074},{"path":"/mnt/mural/club/club_management-main/club_management-main/frontend/node_modules/cache-loader/dist/cjs.js","mtime":1763205488881},{"path":"/mnt/mural/club/club_management-main/club_management-main/frontend/node_modules/babel-loader/lib/index.js","mtime":1763205479187},{"path":"/mnt/mural/club/club_management-main/club_management-main/frontend/node_modules/cache-loader/dist/cjs.js","mtime":1763205488881},{"path":"/mnt/mural/club/club_management-main/club_management-main/frontend/node_modules/vue-loader/lib/index.js","mtime":1763205707195}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";AAsCA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/club-select","sourcesContent":["<template>\n  <div class=\"club-select-page\">\n    <div class=\"header\">\n      <h1>选择您的社团</h1>\n      <el-input\n        v-model=\"searchText\"\n        placeholder=\"搜索社团名称\"\n        prefix-icon=\"el-icon-search\"\n        clearable\n        style=\"max-width: 400px;\"\n      />\n    </div>\n\n    <div v-loading=\"loading\" class=\"club-grid\">\n      <el-card\n        v-for=\"club in filteredClubs\"\n        :key=\"club.id\"\n        class=\"club-card\"\n        :body-style=\"{ padding: '20px' }\"\n        shadow=\"hover\"\n        @click.native=\"selectClub(club)\"\n      >\n        <div class=\"club-logo\">\n          <img v-if=\"club.logoUrl\" :src=\"club.logoUrl\" :alt=\"club.name\" />\n          <div v-else class=\"club-logo-placeholder\" :style=\"{ background: club.themeColor || '#667eea' }\">\n            {{ club.name.substring(0, 2) }}\n          </div>\n        </div>\n        <h3 class=\"club-name\">{{ club.name }}</h3>\n        <p class=\"club-desc\">{{ club.description || '暂无简介' }}</p>\n      </el-card>\n\n      <el-empty v-if=\"!loading && filteredClubs.length === 0\" description=\"未找到匹配的社团\"></el-empty>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { getClubList } from '@/utils/api';\n\nexport default {\n  name: 'ClubSelect',\n  data() {\n    return {\n      clubs: [],\n      searchText: '',\n      loading: false\n    };\n  },\n  computed: {\n    filteredClubs() {\n      if (!this.searchText) return this.clubs;\n      return this.clubs.filter(club =>\n        club.name.toLowerCase().includes(this.searchText.toLowerCase())\n      );\n    }\n  },\n  async mounted() {\n    await this.loadClubs();\n  },\n  methods: {\n    async loadClubs() {\n      this.loading = true;\n      try {\n        const res = await getClubList();\n        if (res.code === 200) {\n          this.clubs = res.data || [];\n        } else {\n          this.$message.error(res.message || '加载社团列表失败');\n        }\n      } catch (e) {\n        this.$message.error('加载社团列表失败');\n        console.error('加载社团列表失败:', e);\n      } finally {\n        this.loading = false;\n      }\n    },\n    async selectClub(club) {\n      try {\n        await this.$store.dispatch('selectClub', club.id);\n        this.$router.push('/login');\n      } catch (e) {\n        this.$message.error('选择社团失败');\n        console.error('选择社团失败:', e);\n      }\n    }\n  }\n};\n</script>\n\n<style lang=\"scss\" scoped>\n.club-select-page {\n  min-height: 100vh;\n  padding: 40px 20px;\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n\n  .header {\n    max-width: 1200px;\n    margin: 0 auto 40px;\n    text-align: center;\n\n    h1 {\n      margin-bottom: 20px;\n      color: #fff;\n      font-size: 32px;\n      font-weight: 600;\n    }\n  }\n\n  .club-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\n    gap: 20px;\n    max-width: 1200px;\n    margin: 0 auto;\n\n    @media (max-width: 768px) {\n      grid-template-columns: 1fr;\n    }\n  }\n\n  .club-card {\n    cursor: pointer;\n    transition: all 0.3s;\n    border-radius: 8px;\n\n    &:hover {\n      transform: translateY(-5px);\n      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);\n    }\n\n    .club-logo {\n      width: 80px;\n      height: 80px;\n      margin: 0 auto 15px;\n      border-radius: 50%;\n      overflow: hidden;\n\n      img {\n        width: 100%;\n        height: 100%;\n        object-fit: cover;\n      }\n\n      &-placeholder {\n        width: 100%;\n        height: 100%;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n        color: white;\n        font-size: 32px;\n        font-weight: bold;\n      }\n    }\n\n    .club-name {\n      text-align: center;\n      margin: 0 0 10px;\n      font-size: 18px;\n      color: #333;\n      font-weight: 600;\n    }\n\n    .club-desc {\n      text-align: center;\n      margin: 0;\n      font-size: 14px;\n      color: #666;\n      line-height: 1.5;\n      max-height: 60px;\n      overflow: hidden;\n      text-overflow: ellipsis;\n      display: -webkit-box;\n      -webkit-line-clamp: 3;\n      -webkit-box-orient: vertical;\n    }\n  }\n}\n</style>\n"]}]}