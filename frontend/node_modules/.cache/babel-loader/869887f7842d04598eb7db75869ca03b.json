return Promise.reject(error);\n    }\n    console.log('响应成功，返回数据');\n    return res;\n  },\n  error => {\n    console.log('响应拦截器出错:', error);\n    return Promise.reject(error);\n  }\n);\n\nexport default service;\n"],"mappings":"AAAA,OAAOA,KAAK,MAAM,OAAO;AACzB,OAAOC,KAAK,MAAM,SAAS;AAE3B,MAAMC,OAAO,GAAGF,KAAK,CAACG,MAAM,CAAC;EAC3BC,OAAO,EAAEC,OAAO,CAACC,GAAG,CAACC,gBAAgB,IAAI,MAAM;EAC/CC,OAAO,EAAE;AACX,CAAC,CAAC;AAEFN,OAAO,CAACO,YAAY,CAACC,OAAO,CAACC,GAAG,CAACC,MAAM,IAAI;EACzC,MAAMC,KAAK,GAAGZ,KAAK,CAACa,KAAK,CAACD,KAAK;EAC/B,IAAIA,KAAK,EAAE;IACTD,MAAM,CAACG,OAAO,CAACC,aAAa,GAAG,UAAUH,KAAK,EAAE;EAClD;EACA,OAAOD,MAAM;AACf,CAAC,CAAC;AAEFV,OAAO,CAACO,YAAY,CAACQ,QAAQ,CAACN,GAAG,CAC/BM,QAAQ,IAAI;EACV;EACA,IAAIA,QAAQ,CAACL,MAAM,CAACM,YAAY,KAAK,MAAM,EAAE;IAC3C,OAAOD,QAAQ;EACjB;EAEA,MAAME,GAAG,GAAGF,QAAQ,CAACG,IAAI;EACzBC,OAAO,CAACC,GAAG,CAAC,YAAY,EAAEH,GAAG,CAAC;EAC9B;EACA,IAAIA,GAAG,CAACI,IAAI,KAAKC,SAAS,IAAIL,GAAG,CAACI,IAAI,KAAK,GAAG,EAAE;IAC9CF,OAAO,CAACC,GAAG,CAAC,eAAe,EAAEH,GAAG,CAACI,IAAI,EAAE,UAAU,EAAEJ,GAAG,CAACM,OAAO,CAAC;IAC/D;IACA,MAAMC,KAAK,GAAG,IAAIC,KAAK,CAACR,GAAG,CAACM,OAAO,IAAI,MAAM,CAAC;IAC9CC,KAAK,CAACT,QAAQ,GAAG;MAAEG,IAAI,EAAED;IAAI,CAAC;IAC9B,OAAOS,OAAO,CAACC,MAAM,CAACH,KAAK,CAAC;EAC9B;EACAL,OAAO,CAACC,GAAG,CAAC,WAAW,CAAC;EACxB,OAAOH,GAAG;AACZ,CAAC,EACDO,KAAK,IAAI;EACPL,OAAO,CAACC,GAAG,CAAC,UAAU,EAAEI,KAAK,CAAC;EAC9B,OAAOE,OAAO,CAACC,MAAM,CAACH,KAAK,CAAC;AAC9B,CACF,CAAC;AAED,eAAexB,OAAO","ignoreList":[]}]}