{"remainingRequest":"E:\\Desktop\\社团\\club\\club_management-main\\club_management-main\\frontend\\node_modules\\babel-loader\\lib\\index.js!E:\\Desktop\\社团\\club\\club_management-main\\club_management-main\\frontend\\src\\utils\\request.js","dependencies":[{"path":"E:\\Desktop\\社团\\club\\club_management-main\\club_management-main\\frontend\\src\\utils\\request.js","mtime":1763297818267},{"path":"E:\\Desktop\\社团\\club\\club_management-main\\club_management-main\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1763211639079},{"path":"E:\\Desktop\\社团\\club\\club_management-main\\club_management-main\\frontend\\node_modules\\babel-loader\\lib\\index.js","mtime":1763211586637}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["axios","Message","MessageBox","store","getToken","service","create","baseURL","process","env","VUE_APP_BASE_API","timeout","interceptors","request","use","config","token","state","headers","error","console","log","Promise","reject","response","res","data","code","message","type","duration","confirm","confirmButtonText","cancelButtonText","then","dispatch","location","reload","Error"],"sources":["E:/Desktop/社团/club/club_management-main/club_management-main/frontend/src/utils/request.js"],"sourcesContent":["import axios from 'axios';\r\nimport { Message, MessageBox } from 'element-ui';\r\nimport store from '@/store';\r\nimport { getToken } from '@/utils/auth';\r\n\r\n// 创建axios实例\r\nconst service = axios.create({\r\n  baseURL: process.env.VUE_APP_BASE_API || '/api', // api base_url，未配置时使用 dev 代理\r\n  timeout: 15000 // 请求超时时间\r\n});\r\n\r\n// request拦截器\r\nservice.interceptors.request.use(\r\n  config => {\n    // 优先使用 Vuex 中的 token，兼容旧逻辑再兜底 Cookies\n    const token = store.state.token || getToken();\n    if (token) {\n      config.headers['Authorization'] = 'Bearer ' + token;\n    }\n    return config;\n  },\n  error => {\r\n    // Do something with request error\r\n    console.log(error); // for debug\r\n    Promise.reject(error);\r\n  }\r\n);\r\n\r\n// response 拦截器\r\nservice.interceptors.response.use(\r\n  response => {\r\n    const res = response.data;\r\n    if (res.code !== 200) {\r\n      Message({\r\n        message: res.message || 'Error',\r\n        type: 'error',\r\n        duration: 5 * 1000\r\n      });\r\n\r\n      // 50008:非法的token; 50012:其他客户端登录了;  50014:Token 过期了;\r\n      if (res.code === 50008 || res.code === 50012 || res.code === 50014) {\r\n        MessageBox.confirm(\r\n          '你已被登出，可以取消继续留在该页面，或者重新登录',\r\n          '确定登出',\r\n          {\r\n            confirmButtonText: '重新登录',\r\n            cancelButtonText: '取消',\r\n            type: 'warning'\r\n          }\r\n        ).then(() => {\r\n          store.dispatch('FedLogOut').then(() => {\r\n            location.reload(); // 为了重新实例化vue-router对象 避免bug\r\n          });\r\n        });\r\n      }\r\n      return Promise.reject(new Error(res.message || 'Error'));\r\n    } else {\r\n      return res;\r\n    }\r\n  },\r\n  error => {\r\n    console.log('err' + error); // for debug\r\n    Message({\r\n      message: error.message,\r\n      type: 'error',\r\n      duration: 5 * 1000\r\n    });\r\n    return Promise.reject(error);\r\n  }\r\n);\r\n\r\nexport default service;\r\n"],"mappings":"AAAA,OAAOA,KAAK,MAAM,OAAO;AACzB,SAASC,OAAO,EAAEC,UAAU,QAAQ,YAAY;AAChD,OAAOC,KAAK,MAAM,SAAS;AAC3B,SAASC,QAAQ,QAAQ,cAAc;;AAEvC;AACA,MAAMC,OAAO,GAAGL,KAAK,CAACM,MAAM,CAAC;EAC3BC,OAAO,EAAEC,OAAO,CAACC,GAAG,CAACC,gBAAgB,IAAI,MAAM;EAAE;EACjDC,OAAO,EAAE,KAAK,CAAC;AACjB,CAAC,CAAC;;AAEF;AACAN,OAAO,CAACO,YAAY,CAACC,OAAO,CAACC,GAAG,CAC9BC,MAAM,IAAI;EACR;EACA,MAAMC,KAAK,GAAGb,KAAK,CAACc,KAAK,CAACD,KAAK,IAAIZ,QAAQ,CAAC,CAAC;EAC7C,IAAIY,KAAK,EAAE;IACTD,MAAM,CAACG,OAAO,CAAC,eAAe,CAAC,GAAG,SAAS,GAAGF,KAAK;EACrD;EACA,OAAOD,MAAM;AACf,CAAC,EACDI,KAAK,IAAI;EACP;EACAC,OAAO,CAACC,GAAG,CAACF,KAAK,CAAC,CAAC,CAAC;EACpBG,OAAO,CAACC,MAAM,CAACJ,KAAK,CAAC;AACvB,CACF,CAAC;;AAED;AACAd,OAAO,CAACO,YAAY,CAACY,QAAQ,CAACV,GAAG,CAC/BU,QA